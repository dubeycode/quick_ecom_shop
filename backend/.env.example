PORT=5000
NODE_ENV=development
MONGODB_URI=url_of_your_mongodb_database
ADMIN_SECRET_KEY=admin_dev@123
SCHEDULER_SECRET_KEY=dev_test@123
CRON_SECRET=your_scheduler_secret_key
